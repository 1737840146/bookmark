{
  "$schema": "https://turborepo.dev/schema.json",
  "env": [
    "DATABASE_URL",
    "NEXT_PUBLIC_APP_URL",
    "BETTER_AUTH_SECRET",
    "BLOB_READ_WRITE_TOKEN",
    "KV_REST_API_TOKEN",
    "KV_REST_API_URL",
    "KV_URL",
    "REDIS_URL",
    "OPENAI_API_KEY" 
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "clean": {
      "cache": false
    }
  }
}
